{
  "compilerOptions": {
    // Environment setup & latest features
    "types": ["bun"],
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,

    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags 
    "noUnusedLocals": true,
    "noUnusedParameters": true,  
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
